# ── 基础设施 ────────────────────────────────
RABBITMQ_URL=amqp://closeclaw:closeclaw@localhost:5672/
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# ── Orchestrator HTTP ────────────────────────
HTTP_ADDR=:8080

# ── Chroma ──────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ── 文案质量控制 ─────────────────────────────
COPY_REVIEW_MIN_SCORE=7
COPY_MAX_REWRITES=2

# ── 去重阈值（0~1，越高越严格）────────────────
DEDUP_THRESHOLD=0.92

# ── 模型 API Keys ────────────────────────────
TAVILY_API_KEY=your_tavily_api_key
QWEN_API_KEY=your_dashscope_api_key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL_35_PLUS=qwen3.5-plus
# Claude 双源配置
# 主源（any）：claude-opus-4-6，质量优先，失败自动切换备用源
CLAUDE_BASE_URL_ANY=https://a-ocnfniawgw.cn-shanghai.fcapp.run
CLAUDE_API_KEY_ANY=your_any_api_key
CLAUDE_MODEL_ANY=claude-opus-4-6
# 备用源（geek）：claude-sonnet-4-6
CLAUDE_BASE_URL_GEEK=https://geekai.co/api/v1
CLAUDE_API_KEY_GEEK=your_geek_api_key
CLAUDE_MODEL_GEEK=claude-sonnet-4-6

# ── 视频输出 ─────────────────────────────────
VIDEO_OUTPUT_DIR=output/videos
VIDEO_ASSETS_DIR=output/assets
TTS_VOICE=zh-CN-XiaoxiaoNeural

# 视频生成后端切换：
# - 默认启用火山 Seedance
# - 如需切回旧模式（本地素材 / Pexels / 内置渐变），改成 classic
VIDEO_GENERATION_BACKEND=doubao_seedance

# 火山引擎 Ark / Doubao Seedance 配置
VOLCENGINE_ARK_BASE_URL=https://ark.cn-beijing.volces.com
VOLCENGINE_ARK_API_KEY=your_volcengine_ark_api_key
# 2026-04 默认先用 1.5 Pro；如后续 2.0 Fast 官方开放稳定 API，再切回 doubao-seedance-2.0-fast
DOUBAO_SEEDANCE_MODEL=doubao-seedance-1-5-pro-251215
DOUBAO_SEEDANCE_DURATION=5
DOUBAO_SEEDANCE_ASPECT_RATIO=9:16
DOUBAO_SEEDANCE_RESOLUTION=1080p
DOUBAO_SEEDANCE_POLL_INTERVAL_SEC=5
DOUBAO_SEEDANCE_TIMEOUT_SEC=180

# classic 模式可选：配置后自动按话题下载科技素材视频作背景
# 免费申请：https://www.pexels.com/api/
PEXELS_API_KEY=

# ── 发布通知 ─────────────────────────────────
# WEBHOOK_TYPE: feishu | wecom | custom
WEBHOOK_TYPE=feishu
PUBLISH_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_token
